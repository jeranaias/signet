# Copy this file to `.env` and fill in the values. Never commit the
# real `.env` -- the .gitignore in the repo root already keeps it out.
#
#   cp .env.example .env
#   # macOS / Linux:
#   echo "SIGNET_HMAC_SECRET=$(openssl rand -hex 32)" >> .env
#   # Windows (PowerShell):
#   #   "SIGNET_HMAC_SECRET=" + (-join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })) | Add-Content .env

# 32-byte hex HMAC secret for the audit chain. Generate with:
#   openssl rand -hex 32
SIGNET_HMAC_SECRET=

# Optional: which upstream the signet container should forward to.
# Defaults to the in-network ollama service.
# SIGNET_UPSTREAM_URL=http://ollama:11434/v1
